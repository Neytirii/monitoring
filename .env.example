# Database
DATABASE_URL=postgresql://monitoring:monitoring@localhost:5432/monitoring

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-very-long-secret
JWT_AGENT_SECRET=change-me-agent-secret

# Server
PORT=3000
HOST=0.0.0.0
# URL publique de l'API backend — utilisée pour générer les commandes d'installation des agents
# Doit pointer vers ce serveur backend (ex: tunnel Cloudflare api.neytiri-space.fr → port 3000)
PUBLIC_URL=https://api.neytiri-space.fr

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@monitoring.example.com
